Cell[CellGroupData[{

Cell["Direct expansion in nome variables", "Section",
 CellChangeTimes->{{3.982059711191906*^9, 
  3.982059719923169*^9}},ExpressionUUID->"4287bdb1-ed8f-452a-867c-\
b70cb8b7f88c"],

Cell["\<\
The functions Ek[weight,order,q1,r,q2] , Chi10[order,q1,r,q2], and \
Chi12[order,q1,r,q2] return truncated Fourier expansions in the nome \
variables q1 = exp(2\[Pi]iT),  r = exp(2\[Pi]iZ), q2 = exp(2\[Pi]iU).\
\>", "Text",
 CellChangeTimes->{{3.98205973275804*^9, 3.982059746361709*^9}, {
  3.982059791022654*^9, 3.982059859226201*^9}, {3.982122471466416*^9, 
  3.98212252326757*^9}},ExpressionUUID->"aaefce67-1fb3-4430-893d-\
900fa8a86a7f"],

