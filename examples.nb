Cell[CellGroupData[{

Cell["Symbolic modular forms in (T,Z,U)", "Section",
 CellChangeTimes->{
  3.982059939564046*^9},ExpressionUUID->"6b022d4c-a6d5-4e62-afdc-\
8d8d367dc5a3"],

Cell["\<\
The symbolic heads E4[T,Z,U], E6[T,Z,U], E10[T,Z,U], E12[T,Z,U], \[Chi]10, \
\[Chi]12 can be replaced by truncated Fourier expansions using \
PrecomputedRules[order].
Derivatives with respect to T, Z, U are also supported through \
PrecomputedRules[n].\
\>", "Text",
 CellChangeTimes->{{3.982059949379953*^9, 3.9820599725778713`*^9}, {
  3.982060007316865*^9, 
  3.9820600268339233`*^9}},ExpressionUUID->"0a39fe45-3644-42c0-97b4-\
b2b1b2537cb7"],

